generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  category    String
  imageUrl    String
  description String?
  pricesJson  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
